enter:
  - echo "Loading Portainer Terraform environment variables..."
  - export SOPS_AGE_KEY_FILE="$PWD/../../age.key"
  - export AWS_ACCESS_KEY_ID=$(sops -d --extract '["R2_TF_PORTAINER_ACCESS_KEY_ID"]' ../../secrets/reposecrets.sops.yml)
  - export AWS_SECRET_ACCESS_KEY=$(sops -d --extract '["R2_TF_PORTAINER_SECRET_ACCESS_KEY"]' ../../secrets/reposecrets.sops.yml)
  - export TF_VAR_portainer_api_key=$(sops -d --extract '["PORTAINER_API_KEY"]' ../../secrets/reposecrets.sops.yml)
  - echo "Done."
leave:
  - echo "Unsetting Portainer Terraform environment variables..."
  - unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY TF_VAR_portainer_api_key
